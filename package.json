{
  "name": "nuvio-tv-web",
  "private": true,
  "type": "module",
  "version": "0.2.4",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:on-release": "node ./scripts/release-build-poller.mjs",
    "install:webos": "node ./scripts/ares-install-webos.mjs",
    "diagnose:enginefs:webos": "node ./scripts/diagnose-enginefs-webos.mjs",
    "inspect:webos": "node ./scripts/ares-inspect-webos.mjs",
    "logs:webos": "node ./scripts/ares-logs-webos.mjs",
    "media:webos-sim": "node --require ./scripts/localhost-listen-patch.cjs ./services/webos/runtime/media-http.cjs",
    "package:tizen": "npm run build && node ./scripts/package-tizen.mjs",
    "package:webos": "npm run build && node ./scripts/package-webos.mjs",
    "serve": "node ./scripts/serve.mjs",
    "sync": "node ./scripts/sync-wrapper.mjs",
    "sync:tizen": "node ./scripts/sync-wrapper.mjs --tizen",
    "sync:webos": "node ./scripts/sync-wrapper.mjs --webos",
    "sync:tizenbrew": "node ./scripts/sync-tizenbrew.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@csstools/postcss-global-data": "^4.0.0",
    "@webos-tools/cli": "^3.2.3",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.4",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.9",
    "postcss-custom-properties": "^15.0.1"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
